[html]
page_title = Change your password on example.org

# Material Symbols icon name shown in the app bar (default: lock).
# Browse icons at https://fonts.google.com/icons
#page_icon = lock

# Override the theme colour (app bar, focus rings, etc.).
# You can also set these via CSS custom properties in a <style> block.
#primary_color = #2e7d32

# Password policy — configure to match your LDAP server's ppolicy.
# By default only a minimum length is required, which matches the
# defaults of Gerrit, Jenkins, and Gitea.
[password]
min_length = 8

# Uncomment to enforce character-class requirements:
#require_uppercase = true
#require_lowercase = true
#require_digit     = true
#require_special   = true

# Admin panel — allows authenticated LDAP users who are members of the
# configured admin group to create users, create groups, and manage
# group memberships.
#[admin]
# DN of the group whose members are granted admin access.
#admin_group_dn = cn=admins,ou=Groups,dc=example,dc=org

# Base DN for new groups created via the admin panel.
# Defaults to the same base as the first LDAP section.
#group_base_dn = ou=Groups,dc=example,dc=org

# Which LDAP section to use for admin authentication and operations.
# Defaults to the first [ldap] / [ldap:*] section.
#ldap_section = ldap:0

[ldap:0]
host = localhost
port = 636
use_ssl = true
base = ou=People,dc=example,dc=org
search_filter = uid={uid}

# TLS certificate verification (only used when use_ssl or use_tls is true)
# tls_req_cert controls certificate validation:
#   demand — require valid certificate (default, most secure)
#   allow  — try to validate, but allow self-signed certs
#   never  — skip certificate validation (insecure, not recommended)
#tls_req_cert = demand
#tls_ca_cert_file = /etc/ssl/certs/ca-certificates.crt

# Connection timeout in seconds (default: 5)
#connect_timeout = 5

# Uncomment for AD / Samba 4
#type = ad
#ad_domain = ad.example.org
#search_filter = sAMAccountName={uid}

# You may specify multiple LDAPs, the password will be changed in all.
# If one fails, the previous password changes are reverted.
#[ldap:1]
#host = localhost
#port = 636
#use_ssl = true
#base = ou=People,dc=example,dc=org
#search_filter = uid={uid}

[server]
server = auto
host = localhost
port = 8080
